<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31) backup/transfer rules. Both cloud backup and
  device-to-device transfer are disabled so the auth token and cached user
  profile can never leave the device via backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
